{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/ingest-profile-alerts",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/ingest-daily",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/ingest-weekly-grid",
      "schedule": "0 7 1 * *"
    },
    {
      "path": "/api/cron/process-scheduled-sms",
      "schedule": "*/15 * * * *"
    }
  ]
}
